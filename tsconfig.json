{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "target": "ES2020",
    "useDefineForClassFields": true
  },
  "include": [
    "src"
  ],
  "exclude": [
    "src/**/*.stories.tsx",
    "src/**/*.stories.ts",
    "src/**/*.test.tsx",
    "src/**/*.test.ts",
    "src/**/__tests__/**",
    "src/components/colaboradores/ColaboradorFormCompleto.tsx",
    "src/components/colaboradores/ColaboradorFormModal.tsx",
    "src/components/esocial/S*.tsx",
    "src/components/esocial/EventoList.tsx",
    "src/components/dashboard/DashboardCustomizer.tsx",
    "src/components/beneficios/ReciboValeTransporte.tsx",
    "src/components/desligamento/CartaDesligamento.tsx",
    "src/components/ferias/AvisoFerias.tsx"
  ]
}